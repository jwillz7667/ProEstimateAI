app_identifier "Res.ProEstimate-AI"
team_id        "487LC4H9U4"

# App Store listing locales deliver should sync. These are listing-level
# localizations, independent of the binary's runtime localizations
# (Localizable.xcstrings covers en + es-MX): Apple lets a listing be
# localized into any storefront language regardless of in-app strings.
# en-GB/en-AU widen English-storefront keyword coverage; es-ES serves the
# Spain storefront with Spain-native copy. deliver only creates/updates
# localizations named here, so any locale added under metadata/ must also
# be listed here or it is silently skipped.
languages [
  "en-US",
  "en-GB",
  "en-AU",
  "es-MX",
  "es-ES"
]

# Never auto-submit — let the `submit` lane do that explicitly so
# `metadata` runs remain safe.
submit_for_review false

# Precheck catches common rejection reasons before uploading.
# In-app purchases are managed through the Subscriptions section of
# App Store Connect rather than Deliver, so skip them.
precheck_include_in_app_purchases false

# Auto-confirm prompts when driven from CI.
force true
