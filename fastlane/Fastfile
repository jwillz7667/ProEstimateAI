default_platform(:ios)

XCODE_PROJECT   = "ProEstimate AI.xcodeproj"
XCODE_SCHEME    = "ProEstimate AI"
BUNDLE_ID       = "Res.ProEstimate-AI"

# All authentication runs through an App Store Connect API key. Three env
# vars are required everywhere:
#
#   APP_STORE_CONNECT_API_KEY_ID         — the 10-char Key ID
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID  — the UUID issuer ID for the key
#   APP_STORE_CONNECT_API_KEY_CONTENT    — the .p8 file contents, base64-encoded
#
# Locally you can source them from ~/.zshrc; in CI they come from GitHub
# Actions secrets (see .github/workflows/testflight.yml).

def make_api_key
  raw = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip

  # Accept either raw PEM (the contents of the .p8 file, including the
  # BEGIN/END PRIVATE KEY headers) or a base64-encoded blob. Pasters
  # routinely mix the two up; autodetect instead of making the human
  # remember which flag to set.
  is_raw_pem = raw.include?("BEGIN PRIVATE KEY")

  app_store_connect_api_key(
    key_id:                ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id:             ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_content:           raw,
    is_key_content_base64: !is_raw_pem,
    in_house:              false
  )
end

platform :ios do
  desc "Build the project from a clean checkout and push it to TestFlight"
  lane :beta do
    api_key = make_api_key

    # Align the build number with whatever App Store Connect has most
    # recently seen for this bundle id, then bump by one. Avoids the
    # "this build is already uploaded" error on re-runs without needing
    # to hand-edit CURRENT_PROJECT_VERSION on every iteration. If the
    # app record hasn't been created in App Store Connect yet the call
    # raises NotFound — fall back to 0 so the archive still runs and
    # fails with a clearer message on upload.
    latest = begin
      latest_testflight_build_number(
        api_key:        api_key,
        app_identifier: BUNDLE_ID,
        initial_build_number: 0
      )
    rescue => e
      UI.important("Could not read TestFlight build number (#{e.class}): #{e.message}")
      UI.important("Assuming this is the first upload. If the App Store Connect app record doesn't exist yet, create it at https://appstoreconnect.apple.com before re-running.")
      0
    end
    next_build = (latest || 0) + 1

    increment_build_number(
      xcodeproj:    XCODE_PROJECT,
      build_number: next_build
    )

    # Code signing on CI uses App Store Connect API key auth so xcodebuild
    # can create / fetch profiles without a login prompt. The workflow
    # writes the .p8 content out before invoking this lane and exports
    # APP_STORE_CONNECT_API_KEY_PATH to point at it.
    key_id        = ENV.fetch("APP_STORE_CONNECT_API_KEY_ID")
    key_issuer_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID")
    key_path      = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    signing_args = [
      "-allowProvisioningUpdates",
      "-authenticationKeyID", key_id,
      "-authenticationKeyIssuerID", key_issuer_id,
    ]
    signing_args += ["-authenticationKeyPath", key_path] if key_path && !key_path.empty?

    build_ios_app(
      project:                XCODE_PROJECT,
      scheme:                 XCODE_SCHEME,
      configuration:          "Release",
      export_method:          "app-store",
      clean:                  true,
      include_bitcode:        false,
      include_symbols:        true,
      skip_profile_detection: true,
      xcargs:                 signing_args.join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Push localized metadata and screenshots to App Store Connect (no binary)"
  lane :metadata do
    deliver(
      api_key:                           make_api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  false,
      skip_metadata:                     false,
      force:                             true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Submit the most recent build for App Store review"
  lane :submit do
    deliver(
      api_key:                           make_api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  false,
      skip_metadata:                     false,
      force:                             true,
      submit_for_review:                 true,
      automatic_release:                 false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa:                     false,
        export_compliance_encryption_updated:      false,
        export_compliance_uses_encryption:         false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Create the Pro subscription group + monthly / annual products via App Store Connect API"
  lane :create_subscriptions do
    require "spaceship"

    # Build a Spaceship::ConnectAPI token directly so we can drive the
    # raw API for things deliver/pilot don't cover.
    key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip
    key_is_pem = key_content.include?("BEGIN PRIVATE KEY")

    if key_is_pem
      tmp_key = File.join(Dir.mktmpdir("asc_sub"), "AuthKey.p8")
      File.write(tmp_key, key_content)
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        filepath: tmp_key
      )
    else
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        key: Base64.decode64(key_content)
      )
    end
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    UI.user_error!("No app with bundle id #{BUNDLE_ID} — create the app record in App Store Connect first.") unless app

    UI.message("Found app #{app.id} — #{app.name}")

    # --- Subscription group: "ProEstimate Pro" ---
    group = app.get_subscription_groups.find { |g| g.reference_name == "ProEstimate Pro" }
    if group.nil?
      UI.message("Creating subscription group ProEstimate Pro...")
      group = Spaceship::ConnectAPI.post_subscription_group(
        app_id: app.id,
        reference_name: "ProEstimate Pro"
      ).to_models.first
      # Localizations so the group name renders correctly in each store.
      Spaceship::ConnectAPI.post_subscription_group_localization(
        subscription_group_id: group.id,
        locale: "en-US",
        name: "ProEstimate Pro"
      )
      Spaceship::ConnectAPI.post_subscription_group_localization(
        subscription_group_id: group.id,
        locale: "es-MX",
        name: "ProEstimate Pro"
      )
    else
      UI.success("Subscription group already exists (#{group.id})")
    end

    # --- Subscription products ---
    existing = group.get_subscriptions || []
    products = [
      {
        product_id: "proestimate.pro.monthly",
        name: "Pro Monthly",
        period: "ONE_MONTH",
        family_sharable: false,
        localizations: [
          { locale: "en-US", name: "Pro Monthly", description: "Full access to all Pro features, billed monthly" },
          { locale: "es-MX", name: "Pro Mensual", description: "Acceso completo a todas las funciones Pro, facturado mensualmente" },
        ]
      },
      {
        product_id: "proestimate.pro.annual",
        name: "Pro Annual",
        period: "ONE_YEAR",
        family_sharable: false,
        localizations: [
          { locale: "en-US", name: "Pro Annual", description: "Full access to all Pro features, billed annually — save 37%" },
          { locale: "es-MX", name: "Pro Anual", description: "Acceso completo a todas las funciones Pro, facturado anualmente — ahorra 37%" },
        ]
      }
    ]

    products.each do |p|
      existing_product = existing.find { |s| s.product_id == p[:product_id] }
      if existing_product
        UI.success("Subscription already exists: #{p[:product_id]}")
        next
      end

      UI.message("Creating subscription #{p[:product_id]}...")
      created = Spaceship::ConnectAPI.post_subscription(
        subscription_group_id: group.id,
        name: p[:name],
        product_id: p[:product_id],
        family_sharable: p[:family_sharable],
        subscription_period: p[:period]
      ).to_models.first

      p[:localizations].each do |loc|
        Spaceship::ConnectAPI.post_subscription_localization(
          subscription_id: created.id,
          locale: loc[:locale],
          name: loc[:name],
          description: loc[:description]
        )
      end
    end

    UI.success("✅ Subscriptions created/verified.")
    UI.important("Pricing + introductory offer (7-day free trial on Monthly) must still be set in App Store Connect — the API requires pricing tier selection that's easier to do in the web UI.")
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception}")
  end
end
