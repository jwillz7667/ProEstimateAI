default_platform(:ios)

XCODE_PROJECT   = "ProEstimate AI.xcodeproj"
XCODE_SCHEME    = "ProEstimate AI"
BUNDLE_ID       = "Res.ProEstimate-AI"

# All authentication runs through an App Store Connect API key. Three env
# vars are required everywhere:
#
#   APP_STORE_CONNECT_API_KEY_ID         — the 10-char Key ID
#   APP_STORE_CONNECT_API_KEY_ISSUER_ID  — the UUID issuer ID for the key
#   APP_STORE_CONNECT_API_KEY_CONTENT    — the .p8 file contents, base64-encoded
#
# Locally you can source them from ~/.zshrc; in CI they come from GitHub
# Actions secrets (see .github/workflows/testflight.yml).

def make_api_key
  raw = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip

  # Accept either raw PEM (the contents of the .p8 file, including the
  # BEGIN/END PRIVATE KEY headers) or a base64-encoded blob. Pasters
  # routinely mix the two up; autodetect instead of making the human
  # remember which flag to set.
  is_raw_pem = raw.include?("BEGIN PRIVATE KEY")

  app_store_connect_api_key(
    key_id:                ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id:             ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_content:           raw,
    is_key_content_base64: !is_raw_pem,
    in_house:              false
  )
end

platform :ios do
  desc "Build the project from a clean checkout and push it to TestFlight"
  lane :beta do
    api_key = make_api_key

    # Align the build number with whatever App Store Connect has most
    # recently seen for this bundle id, then bump by one. Avoids the
    # "this build is already uploaded" error on re-runs without needing
    # to hand-edit CURRENT_PROJECT_VERSION on every iteration. If the
    # app record hasn't been created in App Store Connect yet the call
    # raises NotFound — fall back to 0 so the archive still runs and
    # fails with a clearer message on upload.
    latest = begin
      latest_testflight_build_number(
        api_key:        api_key,
        app_identifier: BUNDLE_ID,
        initial_build_number: 0
      )
    rescue => e
      UI.important("Could not read TestFlight build number (#{e.class}): #{e.message}")
      UI.important("Assuming this is the first upload. If the App Store Connect app record doesn't exist yet, create it at https://appstoreconnect.apple.com before re-running.")
      0
    end
    next_build = (latest || 0) + 1

    increment_build_number(
      xcodeproj:    XCODE_PROJECT,
      build_number: next_build
    )

    # Distribution cert strategy:
    #   - In CI the runner's keychain is ephemeral. Apple caps the team at
    #     three Distribution certificates, so calling `cert` every run
    #     quickly hits "reached the maximum number of available Distribution
    #     certificates." Instead we package the cert + private key once as
    #     a .p12, stash it in DIST_CERT_P12_BASE64 + DIST_CERT_P12_PASSWORD,
    #     and import it into a fresh keychain on each run.
    #   - Locally the dev's login.keychain already has the cert, so we fall
    #     through to the plain `cert` path.
    p12_base64   = ENV["DIST_CERT_P12_BASE64"]
    p12_password = ENV["DIST_CERT_P12_PASSWORD"]
    ci_keychain  = nil

    if p12_base64 && !p12_base64.empty?
      require "securerandom"
      require "base64"
      ci_keychain      = "proestimate-ci.keychain"
      ci_keychain_pass = SecureRandom.hex(16)

      create_keychain(
        name:               ci_keychain,
        password:           ci_keychain_pass,
        default_keychain:   true,
        unlock:             true,
        timeout:            3600,
        lock_when_sleeps:   false,
        add_to_search_list: true
      )

      p12_path = File.join(Dir.mktmpdir("p12"), "dist.p12")
      File.write(p12_path, Base64.decode64(p12_base64))

      import_certificate(
        certificate_path:     p12_path,
        certificate_password: p12_password.to_s,
        keychain_name:        ci_keychain,
        keychain_password:    ci_keychain_pass
      )

      UI.success("Imported Distribution cert from DIST_CERT_P12_BASE64 into #{ci_keychain}")
    else
      cert(
        api_key:              api_key,
        output_path:          "./fastlane/signing",
        generate_apple_certs: true,
        force:                false
      )
    end

    # force:true regenerates the canonical `Res.ProEstimate-AI AppStore`
    # profile against whichever Distribution cert is now in the keychain.
    # Without it, sigh refuses to touch an existing profile whose cert we
    # don't have locally and instead creates a timestamp-suffixed duplicate
    # that drifts further every run.
    #
    # skip_install defaults to false — we need the default. xcodebuild reads
    # profiles from ~/Library/MobileDevice/Provisioning Profiles/ during
    # `archive`, and if the freshly downloaded profile isn't installed
    # there, the archive fails with "No profile for team ... matching ...".
    sigh(
      api_key:         api_key,
      app_identifier:  BUNDLE_ID,
      platform:        "ios",
      output_path:     "./fastlane/signing",
      force:           true
    )

    # sigh only exposes the file path via lane_context — the profile's
    # internal "Name" field (what xcodebuild's PROVISIONING_PROFILE_SPECIFIER
    # matches against) has to be read out of the signed plist. Skipping this
    # and relying on SharedValues::SIGH_NAME silently returns nil, which
    # passes PROVISIONING_PROFILE_SPECIFIER="" to xcodebuild — xcodebuild then
    # auto-matches a stale profile without Sign in with Apple and the archive
    # dies with "requires a provisioning profile with the Sign in with Apple
    # feature."
    require "plist"
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    profile_xml  = `security cms -D -i "#{profile_path}"`
    UI.user_error!("Could not decode #{profile_path}") if profile_xml.empty?
    profile_plist = Plist.parse_xml(profile_xml)
    profile_name  = profile_plist["Name"]
    profile_uuid  = profile_plist["UUID"]
    UI.user_error!("Provisioning profile at #{profile_path} has no Name field") if profile_name.nil? || profile_name.empty?
    UI.important("Using profile '#{profile_name}' (UUID #{profile_uuid}) at #{profile_path}")

    # Switch to manual signing just for this build so xcodebuild uses
    # the profile sigh just created instead of its own cloud path.
    key_id        = ENV.fetch("APP_STORE_CONNECT_API_KEY_ID")
    key_issuer_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID")
    key_path      = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    signing_args = [
      "-authenticationKeyID", key_id,
      "-authenticationKeyIssuerID", key_issuer_id,
    ]
    signing_args += ["-authenticationKeyPath", key_path] if key_path && !key_path.empty?

    build_ios_app(
      project:                XCODE_PROJECT,
      scheme:                 XCODE_SCHEME,
      configuration:          "Release",
      export_method:          "app-store",
      clean:                  true,
      include_bitcode:        false,
      include_symbols:        true,
      skip_profile_detection: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          BUNDLE_ID => profile_name
        }
      },
      xcargs: [
        signing_args.join(" "),
        "CODE_SIGN_STYLE=Manual",
        "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\"",
        "CODE_SIGN_IDENTITY=\"Apple Distribution\""
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    # Runner keychains are ephemeral so this is belt-and-suspenders, but it
    # also matters for the rare self-hosted-runner case where state persists.
    delete_keychain(name: ci_keychain) if ci_keychain
  end

  desc "Push localized metadata and screenshots to App Store Connect (no binary)"
  lane :metadata do
    deliver(
      api_key:                           make_api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  false,
      skip_metadata:                     false,
      force:                             true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Push text metadata only (name/subtitle/keywords/description/promo/notes). Skips screenshots for fast ASO iteration."
  lane :metadata_copy do
    deliver(
      api_key:                           make_api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  true,
      skip_metadata:                     false,
      force:                             true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Push screenshots only (no metadata)."
  lane :metadata_screenshots do
    deliver(
      api_key:                           make_api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  false,
      skip_metadata:                     true,
      force:                             true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Submit the most recent build for App Store review"
  lane :submit do
    api_key = make_api_key

    # Apple typically finishes processing a freshly-uploaded build in
    # 5-30 minutes. Block here until the latest build is out of
    # "PROCESSING" so `deliver` can attach it to the review submission.
    # We poll the raw ASC API because fastlane's `wait_for_build_processing`
    # action isn't available in this version.
    require "spaceship"
    require "net/http"
    require "json"
    require "uri"
    require "base64"

    # Build a Spaceship token — mirrors the setup used elsewhere in this
    # Fastfile so raw ASC requests stay auth'd through the whole poll.
    submit_key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip
    submit_key_is_pem  = submit_key_content.include?("BEGIN PRIVATE KEY")
    submit_token = if submit_key_is_pem
      submit_tmp_key = File.join(Dir.mktmpdir("asc_submit"), "AuthKey.p8")
      File.write(submit_tmp_key, submit_key_content)
      Spaceship::ConnectAPI::Token.create(
        key_id:    ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        filepath:  submit_tmp_key
      )
    else
      Spaceship::ConnectAPI::Token.create(
        key_id:    ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        key:       Base64.decode64(submit_key_content)
      )
    end
    Spaceship::ConnectAPI.token = submit_token

    submit_app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    UI.user_error!("No app with bundle id #{BUNDLE_ID} in App Store Connect") unless submit_app

    asc_get = lambda do |path|
      uri = URI.parse("https://api.appstoreconnect.apple.com/v1/#{path}")
      req = Net::HTTP::Get.new(uri)
      req["Authorization"] = "Bearer #{Spaceship::ConnectAPI.token.text}"
      req["Content-Type"]  = "application/json"
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      res = http.request(req)
      parsed = res.body && !res.body.empty? ? JSON.parse(res.body) : {}
      UI.user_error!("ASC GET #{path} → #{res.code}: #{parsed.inspect}") unless res.is_a?(Net::HTTPSuccess)
      parsed
    end

    deadline = Time.now + 2700 # 45 minutes total
    loop do
      builds_resp = asc_get.call("builds?filter[app]=#{submit_app.id}&sort=-uploadedDate&limit=1")
      latest = (builds_resp["data"] || []).first
      if latest.nil?
        UI.important("No TestFlight build visible yet — waiting 30s...")
      else
        state   = latest.dig("attributes", "processingState")
        version = latest.dig("attributes", "version")
        bnum    = latest.dig("attributes", "version") # version is the Marketing version; build number is elsewhere
        UI.message("Latest build (v#{version}) — processingState: #{state.inspect}")
        case state
        when "VALID"
          UI.success("Build v#{version} is processed — continuing to submit")
          break
        when "FAILED", "INVALID"
          UI.user_error!("Latest build (v#{version}) is in terminal state #{state} — cannot submit")
        end
      end

      if Time.now > deadline
        UI.user_error!("Timed out after 45 minutes waiting for build processing")
      end
      sleep 30
    end

    # ------------------------------------------------------------------
    # Clear any stale review submissions before calling deliver.
    # ASC rejects `deliver(submit_for_review: true)` with
    # "A review submission is already in progress" whenever a prior
    # submission is still open — typically a READY_FOR_REVIEW that was
    # never sent, or a submission sitting in UNRESOLVED_ISSUES after a
    # rejection. We DELETE first (works for not-yet-submitted), fall
    # back to PATCH state: CANCELING (for submissions Apple has touched),
    # and abort cleanly if neither works.
    # Submissions already IN_REVIEW cannot be cancelled via API.
    # ------------------------------------------------------------------
    asc_raw = lambda do |method, path, body = nil|
      uri = URI.parse("https://api.appstoreconnect.apple.com/v1/#{path}")
      req = case method
            when :get    then Net::HTTP::Get.new(uri)
            when :post   then Net::HTTP::Post.new(uri)
            when :patch  then Net::HTTP::Patch.new(uri)
            when :delete then Net::HTTP::Delete.new(uri)
            else raise "Unsupported HTTP method #{method}"
            end
      req["Authorization"] = "Bearer #{Spaceship::ConnectAPI.token.text}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      res = http.request(req)
      parsed = res.body && !res.body.empty? ? JSON.parse(res.body) : {}
      [res.code.to_i, parsed]
    end

    submissions_resp = asc_get.call("reviewSubmissions?filter[app]=#{submit_app.id}&limit=50")
    all_submissions = submissions_resp["data"] || []
    open_submissions = all_submissions.select do |s|
      %w[READY_FOR_REVIEW WAITING_FOR_REVIEW UNRESOLVED_ISSUES].include?(s.dig("attributes", "state"))
    end

    in_review = all_submissions.select { |s| s.dig("attributes", "state") == "IN_REVIEW" }
    unless in_review.empty?
      UI.user_error!("A review submission is currently IN_REVIEW — wait for Apple to finish (or reject it in ASC UI) before re-dispatching.")
    end

    open_submissions.each do |sub|
      sub_id    = sub["id"]
      sub_state = sub.dig("attributes", "state")
      UI.message("Clearing stale review submission #{sub_id} (state: #{sub_state})...")

      # Strategy 1: DELETE (works for READY_FOR_REVIEW, often also for
      # UNRESOLVED_ISSUES since the developer still owns the record).
      del_code, del_body = asc_raw.call(:delete, "reviewSubmissions/#{sub_id}")
      if del_code < 400
        UI.success("Deleted submission #{sub_id}")
        next
      end
      UI.important("DELETE returned #{del_code}: #{(del_body.dig('errors') || []).map { |e| e['detail'] }.join('; ')}")

      # Strategy 2: PATCH state → CANCELING (ASC flips it asynchronously).
      patch_code, patch_body = asc_raw.call(:patch, "reviewSubmissions/#{sub_id}", {
        data: { type: "reviewSubmissions", id: sub_id, attributes: { state: "CANCELING" } }
      })
      if patch_code < 400
        UI.success("Patched submission #{sub_id} to CANCELING")
        next
      end
      UI.important("PATCH state returned #{patch_code}: #{(patch_body.dig('errors') || []).map { |e| e['detail'] }.join('; ')}")

      UI.user_error!("Could not close stale submission #{sub_id} (state: #{sub_state}) via API. Open App Store Connect → App Review → Resolution Center and cancel/reply manually, then re-run this workflow.")
    end

    # Give ASC a beat to flip state before deliver's pre-check runs.
    sleep 15 unless open_submissions.empty?

    deliver(
      api_key:                           api_key,
      skip_binary_upload:                true,
      skip_screenshots:                  false,
      skip_metadata:                     false,
      force:                             true,
      submit_for_review:                 true,
      automatic_release:                 false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa:                     false,
        export_compliance_encryption_updated:      false,
        export_compliance_uses_encryption:         false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Register the bundle id in the Developer Portal (one-time). Enables Sign In with Apple and In-App Purchase capabilities."
  lane :register_bundle_id do
    require "spaceship"

    key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip
    key_is_pem = key_content.include?("BEGIN PRIVATE KEY")

    if key_is_pem
      tmp_key = File.join(Dir.mktmpdir("asc_bid"), "AuthKey.p8")
      File.write(tmp_key, key_content)
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        filepath: tmp_key
      )
    else
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        key: Base64.decode64(key_content)
      )
    end
    Spaceship::ConnectAPI.token = token

    existing = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: BUNDLE_ID }).first
    if existing
      UI.success("Bundle ID #{BUNDLE_ID} already registered (#{existing.id})")
      bundle = existing
    else
      UI.message("Registering #{BUNDLE_ID} in the Developer Portal...")
      bundle = Spaceship::ConnectAPI::BundleId.create(
        name:       "ProEstimate AI",
        identifier: BUNDLE_ID,
        platform:   "IOS",
        seed_id:    nil
      )
      UI.success("Created bundle id #{bundle.id}")
    end

    # Ensure Sign In with Apple + In-App Purchase capabilities are enabled.
    wanted = %w[APPLE_ID_AUTH IN_APP_PURCHASE]
    existing_caps = bundle.get_capabilities.map(&:capability_type)
    wanted.each do |cap|
      if existing_caps.include?(cap)
        UI.success("Capability #{cap} already enabled")
      else
        UI.message("Enabling capability #{cap}...")
        Spaceship::ConnectAPI::BundleIdCapability.create(
          bundle_id_id:    bundle.id,
          capability_type: cap
        )
      end
    end

    UI.success("Bundle ID #{BUNDLE_ID} is ready for signing.")
  end

  desc "Create the Pro subscription group + monthly / annual products via App Store Connect API"
  lane :create_subscriptions do
    require "spaceship"
    require "net/http"
    require "json"
    require "uri"
    require "digest"

    # Build a Spaceship token so we can reuse its JWT generation, but
    # drive the raw App Store Connect JSON:API with Net::HTTP — Spaceship's
    # higher-level models don't expose subscription CRUD.
    key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip
    key_is_pem = key_content.include?("BEGIN PRIVATE KEY")

    if key_is_pem
      tmp_key = File.join(Dir.mktmpdir("asc_sub"), "AuthKey.p8")
      File.write(tmp_key, key_content)
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        filepath: tmp_key
      )
    else
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
        key: Base64.decode64(key_content)
      )
    end
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
    UI.user_error!("No app with bundle id #{BUNDLE_ID} — create the app record in App Store Connect first.") unless app

    UI.message("Found app #{app.id} — #{app.name}")

    api_base = "https://api.appstoreconnect.apple.com/v1"

    # Token auto-refreshes via #text so a long-running lane won't hit
    # the 20-minute JWT expiry mid-run.
    asc_request = lambda do |method, path, body = nil|
      uri = URI.parse(path.start_with?("http") ? path : "#{api_base}/#{path}")
      req = case method
            when :get    then Net::HTTP::Get.new(uri)
            when :post   then Net::HTTP::Post.new(uri)
            when :patch  then Net::HTTP::Patch.new(uri)
            when :delete then Net::HTTP::Delete.new(uri)
            else raise "Unsupported method #{method}"
            end
      req["Authorization"] = "Bearer #{Spaceship::ConnectAPI.token.text}"
      req["Content-Type"]  = "application/json"
      if body
        req.body = body.is_a?(String) ? body : body.to_json
      end

      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      res = http.request(req)

      parsed = res.body && !res.body.empty? ? JSON.parse(res.body) : {}
      unless res.is_a?(Net::HTTPSuccess)
        UI.user_error!("ASC #{method.upcase} #{path} → #{res.code}: #{parsed.inspect}")
      end
      parsed
    end

    # --- Subscription group: "ProEstimate Pro" ---
    groups_resp = asc_request.call(:get, "apps/#{app.id}/subscriptionGroups?limit=200")
    groups = groups_resp["data"] || []
    group = groups.find { |g| g.dig("attributes", "referenceName") == "ProEstimate Pro" }

    if group.nil?
      UI.message("Creating subscription group ProEstimate Pro...")
      create_resp = asc_request.call(:post, "subscriptionGroups", {
        data: {
          type: "subscriptionGroups",
          attributes: { referenceName: "ProEstimate Pro" },
          relationships: {
            app: { data: { type: "apps", id: app.id } }
          }
        }
      })
      group = create_resp["data"]
      group_id = group["id"]

      %w[en-US es-MX].each do |locale|
        asc_request.call(:post, "subscriptionGroupLocalizations", {
          data: {
            type: "subscriptionGroupLocalizations",
            attributes: { locale: locale, name: "ProEstimate Pro", customAppName: "ProEstimate AI" },
            relationships: {
              subscriptionGroup: { data: { type: "subscriptionGroups", id: group_id } }
            }
          }
        })
      end
    else
      group_id = group["id"]
      UI.success("Subscription group already exists (#{group_id})")
    end

    # --- Subscription products ---
    existing_subs_resp = asc_request.call(:get, "subscriptionGroups/#{group_id}/subscriptions?limit=200")
    existing_subs = existing_subs_resp["data"] || []

    products = [
      {
        product_id: "proestimate.pro.monthly",
        name: "Pro Monthly",
        period: "ONE_MONTH",
        family_sharable: false,
        # Base USA price — ASC propagates per-territory via its price matrix.
        base_price_usd: "19.99",
        # Seven-day free trial introductory offer. `numberOfPeriods: 1` with
        # `duration: ONE_WEEK` gives exactly seven days free.
        intro_offer: {
          offerMode:       "FREE_TRIAL",
          duration:        "ONE_WEEK",
          numberOfPeriods: 1,
        },
        localizations: [
          { locale: "en-US", name: "Pro Monthly", description: "Unlimited AI remodels & estimates" },
          { locale: "es-MX", name: "Pro Mensual", description: "Remodelaciones y cotizaciones IA ilimitadas" },
        ]
      },
      {
        product_id: "proestimate.pro.annual",
        name: "Pro Annual",
        period: "ONE_YEAR",
        family_sharable: false,
        base_price_usd: "149.99",
        intro_offer: nil,
        localizations: [
          { locale: "en-US", name: "Pro Annual", description: "Save 37% — all Pro tools, one price" },
          { locale: "es-MX", name: "Pro Anual", description: "Ahorra 37% — todo Pro en un pago" },
        ]
      }
    ]

    # App Review screenshot — same paywall image is attached to every product
    # so the reviewer can always locate the purchase surface.
    screenshot_path = File.expand_path("../app-store-listing/paywall.png", __dir__)

    products.each do |p|
      match = existing_subs.find { |s| s.dig("attributes", "productId") == p[:product_id] }
      if match
        sub_id = match["id"]
        UI.success("Subscription already exists: #{p[:product_id]} (#{sub_id})")
      else
        UI.message("Creating subscription #{p[:product_id]}...")
        sub_resp = asc_request.call(:post, "subscriptions", {
          data: {
            type: "subscriptions",
            attributes: {
              productId:          p[:product_id],
              name:               p[:name],
              subscriptionPeriod: p[:period],
              familySharable:     p[:family_sharable]
            },
            relationships: {
              group: { data: { type: "subscriptionGroups", id: group_id } }
            }
          }
        })
        sub_id = sub_resp.dig("data", "id")
      end

      # Idempotent localization pass — fetch existing, PATCH or POST per locale.
      existing_locs_resp = asc_request.call(:get, "subscriptions/#{sub_id}/subscriptionLocalizations?limit=200")
      existing_locs = existing_locs_resp["data"] || []

      p[:localizations].each do |loc|
        existing = existing_locs.find { |l| l.dig("attributes", "locale") == loc[:locale] }
        if existing
          UI.message("Updating #{p[:product_id]} [#{loc[:locale]}] localization...")
          asc_request.call(:patch, "subscriptionLocalizations/#{existing['id']}", {
            data: {
              type: "subscriptionLocalizations",
              id: existing["id"],
              attributes: { name: loc[:name], description: loc[:description] }
            }
          })
        else
          UI.message("Creating #{p[:product_id]} [#{loc[:locale]}] localization...")
          asc_request.call(:post, "subscriptionLocalizations", {
            data: {
              type: "subscriptionLocalizations",
              attributes: { locale: loc[:locale], name: loc[:name], description: loc[:description] },
              relationships: {
                subscription: { data: { type: "subscriptions", id: sub_id } }
              }
            }
          })
        end
      end

      # ----------------------------------------------------------------
      # USA baseline price.
      # Every subscription needs a price anchor in at least one territory;
      # Apple's pricing matrix fans it out to every other storefront via
      # the customer-price equivalence map. We target USA @ $19.99 / $149.99.
      # Idempotent: if any USA price already exists we leave it alone.
      # ----------------------------------------------------------------
      target_price = p[:base_price_usd]
      if target_price
        existing_prices_resp = asc_request.call(:get, "subscriptions/#{sub_id}/prices?include=territory&limit=200")
        has_usa_price = (existing_prices_resp["data"] || []).any? do |pr|
          pr.dig("relationships", "territory", "data", "id") == "USA"
        end

        if has_usa_price
          UI.success("#{p[:product_id]} already has USA pricing set")
        else
          # Find the USA price point whose customerPrice matches our target.
          pp_resp = asc_request.call(:get, "subscriptions/#{sub_id}/pricePoints?filter[territory]=USA&limit=8000")
          price_point = (pp_resp["data"] || []).find do |pp|
            pp.dig("attributes", "customerPrice").to_f == target_price.to_f
          end

          if price_point.nil?
            UI.important("No $#{target_price} USD price point found for #{p[:product_id]} — skipping pricing. Check ASC manually.")
          else
            UI.message("Setting #{p[:product_id]} USA price to $#{target_price}...")
            asc_request.call(:post, "subscriptionPrices", {
              data: {
                type: "subscriptionPrices",
                attributes: { preserveCurrentPrice: false },
                relationships: {
                  subscription:           { data: { type: "subscriptions",          id: sub_id             } },
                  subscriptionPricePoint: { data: { type: "subscriptionPricePoints", id: price_point["id"] } },
                  territory:              { data: { type: "territories",             id: "USA"             } },
                }
              }
            })
            UI.success("USA price set for #{p[:product_id]}")
          end
        end
      end

      # ----------------------------------------------------------------
      # Introductory offer — monthly only gets the 7-day free trial.
      # ASC scopes intro offers per-territory, so we create one entry
      # per storefront we care about. USA is the launch priority;
      # additional territories can be layered on by extending the list.
      # Idempotent: skip if an intro offer already exists for that
      # territory.
      # ----------------------------------------------------------------
      intro = p[:intro_offer]
      if intro
        intros_resp = asc_request.call(:get, "subscriptions/#{sub_id}/introductoryOffers?include=territory&limit=200")
        existing_intros = intros_resp["data"] || []

        intro_territories = ["USA"]
        intro_territories.each do |territory_id|
          already_present = existing_intros.any? do |offer|
            offer.dig("relationships", "territory", "data", "id") == territory_id
          end

          if already_present
            UI.success("#{p[:product_id]} already has an intro offer in #{territory_id}")
            next
          end

          UI.message("Creating 7-day free trial for #{p[:product_id]} in #{territory_id}...")
          asc_request.call(:post, "subscriptionIntroductoryOffers", {
            data: {
              type: "subscriptionIntroductoryOffers",
              attributes: {
                duration:        intro[:duration],
                numberOfPeriods: intro[:numberOfPeriods],
                offerMode:       intro[:offerMode],
              },
              relationships: {
                subscription: { data: { type: "subscriptions", id: sub_id       } },
                territory:    { data: { type: "territories",   id: territory_id } },
              }
            }
          })
          UI.success("Intro offer created for #{p[:product_id]} in #{territory_id}")
        end
      end

      # ----------------------------------------------------------------
      # App Review screenshot — 2.1(b) blocker. Apple won't review an IAP
      # without a screenshot showing the purchase surface. Uploaded via
      # the reservation → PUT → commit flow documented on the
      # subscriptionAppStoreReviewScreenshots resource.
      # Idempotent: skip if the subscription already has a screenshot.
      # ----------------------------------------------------------------
      if File.exist?(screenshot_path)
        existing_shots_resp = asc_request.call(:get, "subscriptions/#{sub_id}/appStoreReviewScreenshot")
        already_has_screenshot = !existing_shots_resp.dig("data").nil?

        if already_has_screenshot
          UI.success("#{p[:product_id]} already has a review screenshot")
        else
          UI.message("Uploading review screenshot for #{p[:product_id]}...")
          file_bytes = File.binread(screenshot_path)
          file_size  = file_bytes.bytesize
          file_name  = File.basename(screenshot_path)

          # 1. Reserve — Apple returns an upload plan with one or more PUT URLs.
          create_resp = asc_request.call(:post, "subscriptionAppStoreReviewScreenshots", {
            data: {
              type: "subscriptionAppStoreReviewScreenshots",
              attributes: { fileName: file_name, fileSize: file_size },
              relationships: {
                subscription: { data: { type: "subscriptions", id: sub_id } }
              }
            }
          })
          screenshot_id = create_resp.dig("data", "id")
          upload_ops    = create_resp.dig("data", "attributes", "uploadOperations") || []

          if screenshot_id.nil? || upload_ops.empty?
            UI.user_error!("ASC didn't return upload operations for #{p[:product_id]} screenshot: #{create_resp.inspect}")
          end

          # 2. Stream bytes to each upload URL — large files may be chunked.
          upload_ops.each do |op|
            uri = URI.parse(op["url"])
            http = Net::HTTP.new(uri.host, uri.port)
            http.use_ssl = uri.scheme == "https"
            req = Net::HTTP::Put.new(uri)
            (op["requestHeaders"] || []).each { |h| req[h["name"]] = h["value"] }
            req.body = if op["offset"] && op["length"]
                         file_bytes.byteslice(op["offset"], op["length"])
                       else
                         file_bytes
                       end
            upload_res = http.request(req)
            unless upload_res.is_a?(Net::HTTPSuccess)
              UI.user_error!("Screenshot upload failed (#{upload_res.code}): #{upload_res.body.to_s[0..500]}")
            end
          end

          # 3. Commit — ASC verifies the uploaded bytes via the MD5 checksum.
          checksum = Digest::MD5.hexdigest(file_bytes)
          asc_request.call(:patch, "subscriptionAppStoreReviewScreenshots/#{screenshot_id}", {
            data: {
              type: "subscriptionAppStoreReviewScreenshots",
              id:   screenshot_id,
              attributes: { uploaded: true, sourceFileChecksum: checksum }
            }
          })
          UI.success("Review screenshot uploaded for #{p[:product_id]}")
        end
      else
        UI.important("Review screenshot not found at #{screenshot_path} — upload manually in ASC.")
      end
    end

    UI.success("Subscriptions created, priced, trial configured, screenshots uploaded.")
    UI.important("Products are now 'Ready to Submit' — they'll be bundled with the next App Store submission.")
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception}")
  end
end
