    "After the %@, your %@ subscription automatically renews at %@ unless canceled at least 24 hours before the end of the current period. Your Apple ID will be charged for renewal within 24 hours prior to the end of each billing period." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "After the %1$@, your %2$@ subscription automatically renews at %3$@ unless canceled at least 24 hours before the end of the current period. Your Apple ID will be charged for renewal within 24 hours prior to the end of each billing period."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Después del %1$@, tu suscripción %2$@ se renueva automáticamente por %3$@ a menos que se cancele al menos 24 horas antes del final del período actual. Se cobrará a tu Apple ID la renovación dentro de las 24 horas anteriores al final de cada período de facturación."
          }
        }
      }
    },
    "After the %@, your subscription will automatically renew at %@ %@ unless cancelled at least 24 hours before the end of the current period." : {
      "comment" : "A sentence explaining that a free trial period will follow a subscription renewal, and then that the subscription will renew automatically at a specified price. The first argument is a user-visible introductory offer description. The second argument is the formatted price of the subscription. The third argument is a user-visible billing period label (e.g., \"month\").",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "After the %1$@, your subscription will automatically renew at %2$@ %3$@ unless cancelled at least 24 hours before the end of the current period."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tras el %1$@, tu suscripción se renovará automáticamente por %2$@ %3$@ a menos que la canceles al menos 24 horas antes del final del período actual."
          }
        }
      }
    },
