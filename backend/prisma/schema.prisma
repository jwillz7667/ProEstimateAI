generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  ESTIMATOR
  VIEWER
}

enum ProjectType {
  KITCHEN
  BATHROOM
  FLOORING
  ROOFING
  PAINTING
  SIDING
  ROOM_REMODEL
  EXTERIOR
  CUSTOM
}

enum ProjectStatus {
  DRAFT
  PHOTOS_UPLOADED
  GENERATING
  GENERATION_COMPLETE
  ESTIMATE_CREATED
  PROPOSAL_SENT
  APPROVED
  DECLINED
  INVOICED
  COMPLETED
  ARCHIVED
}

enum QualityTier {
  STANDARD
  PREMIUM
  LUXURY
}

enum AssetType {
  ORIGINAL
  AI_GENERATED
  DOCUMENT
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
}

enum LineItemCategory {
  MATERIALS
  LABOR
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  DECLINED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PlanCode {
  FREE_STARTER
  PRO_MONTHLY
  PRO_ANNUAL
}

enum EntitlementStatus {
  FREE
  TRIAL_ACTIVE
  PRO_ACTIVE
  GRACE_PERIOD
  BILLING_RETRY
  CANCELED_ACTIVE
  EXPIRED
  REVOKED
}

enum UsageMetricCode {
  AI_GENERATION
  QUOTE_EXPORT
}

enum UsageResetPolicy {
  NEVER
  MONTHLY
}

enum SubscriptionEventType {
  PURCHASED
  RENEWED
  TRIAL_STARTED
  TRIAL_CONVERTED
  CANCELED
  EXPIRED
  GRACE_PERIOD_STARTED
  BILLING_RETRY_STARTED
  REVOKED
  RESTORED
}

enum PurchaseAttemptStatus {
  PENDING
  COMPLETED
  FAILED
  ABANDONED
}

enum ActivityAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  IMAGE_UPLOADED
  GENERATION_STARTED
  GENERATION_COMPLETED
  ESTIMATE_CREATED
  ESTIMATE_UPDATED
  PROPOSAL_SENT
  PROPOSAL_VIEWED
  PROPOSAL_APPROVED
  PROPOSAL_DECLINED
  INVOICE_CREATED
  INVOICE_SENT
  INVOICE_PAID
}

// ─── AUTH ─────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  passwordHash String?
  fullName     String
  role         UserRole @default(OWNER)
  avatarUrl    String?
  phone        String?
  appleUserId  String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company          @relation(fields: [companyId], references: [id])
  refreshTokens  RefreshToken[]
  activityLogs   ActivityLogEntry[]
  entitlement    UserEntitlement?
  usageBuckets   UsageBucket[]
  usageEvents    UsageEvent[]
  purchaseAttempts PurchaseAttempt[]

  @@index([companyId])
}

model Company {
  id                   String   @id @default(cuid())
  name                 String
  phone                String?
  email                String?
  address              String?
  city                 String?
  state                String?
  zip                  String?
  logoUrl              String?
  primaryColor         String?  @default("#F97316")
  secondaryColor       String?
  defaultTaxRate       Decimal? @db.Decimal(5, 4)
  defaultMarkupPercent Decimal? @db.Decimal(5, 2)
  estimatePrefix       String?  @default("EST")
  invoicePrefix        String?  @default("INV")
  nextEstimateNumber   Int      @default(1001)
  nextInvoiceNumber    Int      @default(1001)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users           User[]
  clients         Client[]
  projects        Project[]
  estimates       Estimate[]
  proposals       Proposal[]
  invoices        Invoice[]
  pricingProfiles PricingProfile[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── DOMAIN ──────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  projects Project[]
  invoices Invoice[]

  @@index([companyId])
}

model Project {
  id            String        @id @default(cuid())
  companyId     String
  clientId      String?
  title         String
  description   String?
  projectType   ProjectType   @default(CUSTOM)
  status        ProjectStatus @default(DRAFT)
  budgetMin     Decimal?      @db.Decimal(12, 2)
  budgetMax     Decimal?      @db.Decimal(12, 2)
  qualityTier   QualityTier   @default(STANDARD)
  squareFootage Decimal?      @db.Decimal(10, 2)
  dimensions    String?
  language      String?       @default("en")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  client       Client?          @relation(fields: [clientId], references: [id])
  assets       Asset[]
  generations  AIGeneration[]
  estimates    Estimate[]
  proposals    Proposal[]
  invoices     Invoice[]
  activityLogs ActivityLogEntry[]

  @@index([companyId])
  @@index([clientId])
}

model Asset {
  id           String   @id @default(cuid())
  projectId    String
  url          String
  thumbnailUrl String?
  assetType    AssetType @default(ORIGINAL)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AIGeneration {
  id                   String           @id @default(cuid())
  projectId            String
  prompt               String
  systemPrompt         String?
  status               GenerationStatus @default(QUEUED)
  previewUrl           String?
  thumbnailUrl         String?
  imageData            String?          @db.Text
  imageMimeType        String?
  generationDurationMs Int?
  errorMessage         String?
  createdAt            DateTime         @default(now())

  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materials MaterialSuggestion[]

  @@index([projectId])
}

model MaterialSuggestion {
  id            String  @id @default(cuid())
  generationId  String
  projectId     String
  name          String
  category      String
  estimatedCost Decimal @db.Decimal(12, 2)
  unit          String
  quantity      Decimal @db.Decimal(10, 2)
  supplierName  String?
  supplierUrl   String?
  isSelected    Boolean @default(false)
  sortOrder     Int     @default(0)

  generation AIGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
}

// ─── ESTIMATES ───────────────────────────────────────────

model Estimate {
  id                String         @id @default(cuid())
  projectId         String
  companyId         String
  estimateNumber    String
  version           Int            @default(1)
  status            EstimateStatus @default(DRAFT)
  subtotalMaterials Decimal        @db.Decimal(12, 2) @default(0)
  subtotalLabor     Decimal        @db.Decimal(12, 2) @default(0)
  subtotalOther     Decimal        @db.Decimal(12, 2) @default(0)
  taxAmount         Decimal        @db.Decimal(12, 2) @default(0)
  discountAmount    Decimal        @db.Decimal(12, 2) @default(0)
  totalAmount       Decimal        @db.Decimal(12, 2) @default(0)
  notes             String?
  validUntil        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  project   Project            @relation(fields: [projectId], references: [id])
  company   Company            @relation(fields: [companyId], references: [id])
  lineItems EstimateLineItem[]
  proposals Proposal[]

  @@unique([companyId, estimateNumber])
  @@index([projectId])
  @@index([companyId])
}

model EstimateLineItem {
  id            String           @id @default(cuid())
  estimateId    String
  category      LineItemCategory @default(MATERIALS)
  name          String
  description   String?
  quantity      Decimal          @db.Decimal(10, 2)
  unit          String
  unitCost      Decimal          @db.Decimal(12, 2)
  markupPercent Decimal          @db.Decimal(5, 2) @default(0)
  taxRate       Decimal          @db.Decimal(5, 4) @default(0)
  lineTotal     Decimal          @db.Decimal(12, 2) @default(0)
  sortOrder     Int              @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

// ─── PROPOSALS ───────────────────────────────────────────

model Proposal {
  id                  String         @id @default(cuid())
  estimateId          String
  projectId           String
  companyId           String
  status              ProposalStatus @default(DRAFT)
  shareToken          String?        @unique
  heroImageUrl        String?
  termsAndConditions  String?
  clientMessage       String?
  sentAt              DateTime?
  viewedAt            DateTime?
  respondedAt         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime       @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@index([projectId])
  @@index([companyId])
}

// ─── INVOICES ────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  estimateId    String?
  projectId     String
  companyId     String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount     Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount   Decimal       @db.Decimal(12, 2) @default(0)
  amountPaid    Decimal       @db.Decimal(12, 2) @default(0)
  amountDue     Decimal       @db.Decimal(12, 2) @default(0)
  dueDate       DateTime?
  paidAt        DateTime?
  sentAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project   Project           @relation(fields: [projectId], references: [id])
  company   Company           @relation(fields: [companyId], references: [id])
  client    Client            @relation(fields: [clientId], references: [id])
  lineItems InvoiceLineItem[]

  @@unique([companyId, invoiceNumber])
  @@index([projectId])
  @@index([companyId])
  @@index([clientId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  quantity    Decimal @db.Decimal(10, 2)
  unit        String
  unitCost    Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2) @default(0)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── SETTINGS ────────────────────────────────────────────

model PricingProfile {
  id                   String  @id @default(cuid())
  companyId            String
  name                 String
  defaultMarkupPercent Decimal @db.Decimal(5, 2) @default(20)
  contingencyPercent   Decimal @db.Decimal(5, 2) @default(10)
  wasteFactor          Decimal @db.Decimal(5, 2) @default(5)
  isDefault            Boolean @default(false)
  createdAt            DateTime @default(now())

  company    Company         @relation(fields: [companyId], references: [id])
  laborRates LaborRateRule[]

  @@index([companyId])
}

model LaborRateRule {
  id               String  @id @default(cuid())
  pricingProfileId String
  category         String
  ratePerHour      Decimal @db.Decimal(10, 2)
  minimumHours     Decimal @db.Decimal(10, 2) @default(1)

  pricingProfile PricingProfile @relation(fields: [pricingProfileId], references: [id], onDelete: Cascade)

  @@index([pricingProfileId])
}

// ─── ACTIVITY ────────────────────────────────────────────

model ActivityLogEntry {
  id          String         @id @default(cuid())
  projectId   String
  userId      String?
  action      ActivityAction
  description String
  createdAt   DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([projectId])
}

// ─── COMMERCE ────────────────────────────────────────────

model Plan {
  id           String   @id @default(cuid())
  code         PlanCode @unique
  displayName  String
  description  String
  featuresJson Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  products    SubscriptionProduct[]
  entitlements UserEntitlement[]
}

model SubscriptionProduct {
  id                    String   @id @default(cuid())
  planId                String
  storeProductId        String   @unique
  displayName           String
  description           String
  priceDisplay          String
  billingPeriodLabel    String
  hasIntroOffer         Boolean  @default(false)
  introOfferDisplayText String?
  isFeatured            Boolean  @default(false)
  savingsText           String?
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
}

model UserEntitlement {
  id                 String            @id @default(cuid())
  userId             String            @unique
  companyId          String
  planId             String
  status             EntitlementStatus @default(FREE)
  storeProductId     String?
  originalTransactionId String?
  renewalDate        DateTime?
  trialEndsAt        DateTime?
  gracePeriodEndsAt  DateTime?
  isAutoRenewEnabled Boolean?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user   User @relation(fields: [userId], references: [id])
  plan   Plan @relation(fields: [planId], references: [id])
  events SubscriptionEvent[]

  @@index([companyId])
}

model SubscriptionEvent {
  id              String                @id @default(cuid())
  entitlementId   String
  eventType       SubscriptionEventType
  storeProductId  String?
  transactionId   String?
  environment     String?
  metadata        Json?
  createdAt       DateTime              @default(now())

  entitlement UserEntitlement @relation(fields: [entitlementId], references: [id])

  @@index([entitlementId])
}

model UsageBucket {
  id               String          @id @default(cuid())
  userId           String
  companyId        String
  metricCode       UsageMetricCode
  includedQuantity Int
  consumedQuantity Int             @default(0)
  resetPolicy      UsageResetPolicy @default(NEVER)
  periodStart      DateTime?
  periodEnd        DateTime?
  source           String          @default("STARTER_CREDITS")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, metricCode])
  @@index([companyId])
}

model UsageEvent {
  id         String          @id @default(cuid())
  userId     String
  companyId  String
  metricCode UsageMetricCode
  quantity   Int             @default(1)
  metadata   Json?
  createdAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([companyId])
}

model PaywallImpression {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  placement   String
  action      String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model PurchaseAttempt {
  id               String                @id @default(cuid())
  userId           String
  companyId        String
  productId        String
  placement        String?
  appAccountToken  String                @unique
  status           PurchaseAttemptStatus @default(PENDING)
  transactionId    String?
  completedAt      DateTime?
  createdAt        DateTime              @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([appAccountToken])
}
