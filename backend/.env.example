# ─────────────────────────────────────────────────────────────────────────
# Required — backend will refuse to boot without these
# ─────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://user:password@localhost:5432/proestimate?schema=public"
JWT_SECRET="your-jwt-secret-at-least-32-chars-long-replace-this-with-a-real-secret-key"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-at-least-32-chars-long-replace-this-with-a-real-secret"

# ─────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
API_BASE_URL=https://proestimate-api-production.up.railway.app

# ─────────────────────────────────────────────────────────────────────────
# AI image generation — at least ONE of PIAPI_API_KEY or GOOGLE_AI_API_KEY
# must be set. PiAPI is tried first, Google GenAI is the fallback.
# ─────────────────────────────────────────────────────────────────────────

PIAPI_API_KEY=your-piapi-key-for-nano-banana-pro
GOOGLE_AI_API_KEY=your-google-ai-api-key-for-nano-banana-fallback

# AI estimate text generation (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ─────────────────────────────────────────────────────────────────────────
# APNs — Apple Push Notification service. Required to deliver
# "preview ready" pushes when the app is killed. If any var is missing
# the backend logs a warning once and silently skips push delivery
# (in-app polling still works).
#
# Where to find each:
#   APNS_KEY_ID         — developer.apple.com → Keys → your APNs key
#   APNS_TEAM_ID        — developer.apple.com → Membership → Team ID
#   APNS_BUNDLE_ID      — must match the iOS bundle ID exactly
#   APNS_PRIVATE_KEY    — full contents of the .p8 file you downloaded
#                         (Apple only lets you download once; literal \n
#                         escapes and real newlines are both accepted)
#   APNS_PRODUCTION     — true for App Store / TestFlight (api.push.apple.com)
#                         false / unset for Xcode debug builds (sandbox)
# ─────────────────────────────────────────────────────────────────────────

APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=Res.ProEstimate-AI
APNS_PRIVATE_KEY=
APNS_PRODUCTION=false

# ─────────────────────────────────────────────────────────────────────────
# Apple sign-in / commerce
# App Store Server API: when issuer ID + key ID + PEM are all set the
# backend cross-checks JWS-verified transactions against Apple's
# authoritative history. Missing values skip the cross-check.
# ─────────────────────────────────────────────────────────────────────────

APP_STORE_ISSUER_ID=
APP_STORE_API_KEY_ID=
APP_STORE_API_PRIVATE_KEY=
APP_STORE_ENVIRONMENT=Production

# ─────────────────────────────────────────────────────────────────────────
# Google OAuth — accepts either client ID as `aud` so a future Next.js
# web app can share this backend without a separate verifier path.
# ─────────────────────────────────────────────────────────────────────────

GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Google Cloud — single API key with Geocoding, Maps Static, and Solar
# (Building Insights) APIs enabled. Powers lawn polygon geocoding,
# roof scouting, and the static-map proxy.
# ─────────────────────────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=
RESEND_FROM_EMAIL=ProEstimate AI <noreply@proestimateai.com>

# ─────────────────────────────────────────────────────────────────────────
# Optional integrations
# ─────────────────────────────────────────────────────────────────────────

# Materials pricing search
SERPAPI_API_KEY=

# Rate-limit + cache backing store (falls back to in-memory if unset)
REDIS_URL=

# Comma-separated list of admin email addresses
ADMIN_EMAILS=
