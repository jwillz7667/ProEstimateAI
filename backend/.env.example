DATABASE_URL="postgresql://user:password@localhost:5432/proestimate?schema=public"
JWT_SECRET="your-jwt-secret-at-least-64-chars-long-replace-this-with-a-real-secret-key"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-at-least-64-chars-long-replace-this-with-a-real-secret"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Image generation — at least one must be set (PiAPI is tried first)
PIAPI_API_KEY=your-piapi-key-for-nano-banana-pro
GOOGLE_AI_API_KEY=your-google-ai-api-key-for-nano-banana-fallback

# AI estimate generation — DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Optional
RESEND_API_KEY=
GOOGLE_PLACES_API_KEY=
SERPAPI_API_KEY=
REDIS_URL=
API_BASE_URL=https://proestimate-api-production.up.railway.app
