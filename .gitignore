# Local docs, specs, and notes (not part of the shipping app)
/CLAUDE.md
/project-specs/
/docs/

# Screenshots — the root screenshots/ folder and loose captures dropped at root
/screenshots/
/Screenshot*.png
/Simulator Screenshot*.png

# Source thumbnails for the project-type tiles. These are the unprocessed
# 62-image PNG dump that gets resized to JPG and imported under
# Assets.xcassets/CategoryThumbs/ — the shipping JPGs are tracked, the
# raw originals stay local (~100MB).
/category-thumbs/

# Source HEICs for the dedicated category tiles and per-category style
# cards. The shipping copies live inside Assets.xcassets/CategoryTiles/
# and Assets.xcassets/StyleCards/ (tracked); the staging folders stay
# local so we don't double-store them.
/category_tiles_heic/
/style_cards_heic/

# macOS
.DS_Store

# Ruby / Fastlane
vendor/bundle/
.bundle/

# Fastlane build artifacts — generated on every run, not worth tracking.
# Screenshots under fastlane/screenshots/** ARE tracked (hand-curated
# App Store assets); only auto-generated run artifacts get ignored.
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/

# Xcode archives and signing artifacts
*.ipa
*.xcarchive
*.dSYM.zip
*.mobileprovision
*.p8
*.p12
.secrets-staging/

/app-store-listing/

# App Store preview videos — re-encoded locally, uploaded to ASC, not tracked.
/preview-*.mp4
/preview.mp4
/preview good.mp4
/0430*.mp4

# Local screenshot staging directories
/new-screenshots/

# Claude Code session artifacts
/.claude/
/build/